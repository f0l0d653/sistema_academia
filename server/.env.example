# ==============================================================================
# CONFIGURAÇÕES DO SERVIDOR (BACKEND) - DEVSQUAD
# ==============================================================================

# Porta onde a API do Express vai rodar localmente
PORT=5000

# URL de conexão com o banco de dados local (SQLite)
# O Prisma usará este caminho para ler/escrever no arquivo dev.db
DATABASE_URL="file:./prisma/dev.db"

# Exemplo de chave secreta para Tokens JWT (usado no futuro para login/autenticação)
# JWT_SECRET="coloque_uma_chave_super_secreta_aqui"
